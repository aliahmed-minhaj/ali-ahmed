{{ 'component-gift-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign top_image = section.settings.top_image
  assign bottom_image = section.settings.bottom_image
  assign mobile_image = section.settings.mobile_image

  assign heading_desktop = section.settings.heading_desktop
  assign subheading_desktop = section.settings.subheading_desktop
  assign btn_label_desktop = section.settings.button_label_desktop
  assign btn_link_desktop = section.settings.button_link_desktop
  assign bottom_text_desktop = section.settings.bottom_bar_text_desktop

  assign heading_mobile = section.settings.heading_mobile
  assign subheading_mobile = section.settings.subheading_mobile
  assign eyebrow_mobile = section.settings.eyebrow_mobile
  assign note_mobile = section.settings.note_mobile
  assign btn_label_mobile = section.settings.button_label_mobile
  assign btn_link_mobile = section.settings.button_link_mobile
  assign bottom_text_mobile = section.settings.bottom_bar_text_mobile
-%}

<section
  class="gift-banner color-{{ section.settings.color_scheme }}"
  id="GiftBanner-{{ section.id }}"
  style="
    --gb-bg: {{ section.settings.background_color }};
    --gb-heading-color: {{ section.settings.heading_color }};
    --gb-subheading-color: {{ section.settings.subheading_color }};
    --gb-btn-bg: {{ section.settings.button_bg_color }};
    --gb-btn-text: {{ section.settings.button_text_color }};
    --gb-bottom-bg: {{ section.settings.bottom_bar_bg_color }};
    --gb-bottom-text: {{ section.settings.bottom_bar_text_color }};
    --gb-text-col-width: {{ section.settings.text_col_width }}%;
    --gb-top-image-ratio: {{ section.settings.top_image_ratio_w }} / {{ section.settings.top_image_ratio_h }};
    --gb-split-row-ratio: {{ section.settings.split_row_ratio_w }} / {{ section.settings.split_row_ratio_h }};
    --gb-mobile-image-ratio: {{ section.settings.mobile_image_ratio_w }} / {{ section.settings.mobile_image_ratio_h }};
  ">

  <!-- ================= DESKTOP VERSION ================= -->
  <!-- 3 parts: 1) top image (full width)  2) text column  3) bottom-right image -->
  <div class="gift-banner__desktop">

    <div class="gift-banner__top-image">
      {%- if top_image -%}
        <img
          src="{{ top_image | image_url: width: 2000 }}"
          srcset="{{ top_image | image_url: width: 1200 }} 1200w, {{ top_image | image_url: width: 2000 }} 2000w"
          sizes="100vw"
          width="{{ top_image.width }}"
          height="{{ top_image.height }}"
          alt="{{ top_image.alt | default: heading_desktop | escape }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="gift-banner__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      {%- endif -%}
    </div>

    <div class="gift-banner__split-row">
      <div class="gift-banner__text-col">
        {%- if heading_desktop != blank -%}
          <h2 class="gift-banner__heading" style="font-size: {{ section.settings.heading_font_size_desktop }}px;">
            {{ heading_desktop }}
          </h2>
        {%- endif -%}
        {%- if subheading_desktop != blank -%}
          <div class="gift-banner__subheading" style="font-size: {{ section.settings.subheading_font_size_desktop }}px;">
            {{ subheading_desktop | newline_to_br }}
          </div>
        {%- endif -%}
        {%- if btn_label_desktop != blank -%}
          <a href="{{ btn_link_desktop | default: '#' }}" class="gift-banner__button black" style="font-size: {{ section.settings.button_font_size_desktop }}px;">
            <span>{{ btn_label_desktop }}</span>
            <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <div class="gift-banner__image-col">
        {%- if bottom_image -%}
          <img
            src="{{ bottom_image | image_url: width: 1400 }}"
            srcset="{{ bottom_image | image_url: width: 800 }} 800w, {{ bottom_image | image_url: width: 1400 }} 1400w"
            sizes="(min-width: 750px) 50vw, 100vw"
            width="{{ bottom_image.width }}"
            height="{{ bottom_image.height }}"
            alt="{{ bottom_image.alt | default: heading_desktop | escape }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="gift-banner__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
    </div>

    {%- if bottom_text_desktop != blank -%}
      <div class="gift-banner__bottom-bar">
        <p>{{ bottom_text_desktop }}</p>
      </div>
    {%- endif -%}
  </div>

  <!-- ================= MOBILE VERSION ================= -->
  <div class="gift-banner__mobile">

    <div class="gift-banner__mobile-top">
      {%- if eyebrow_mobile != blank -%}
        <p class="gift-banner__eyebrow">{{ eyebrow_mobile }}</p>
      {%- endif -%}
      {%- if heading_mobile != blank -%}
        <h2 class="gift-banner__heading" style="font-size: {{ section.settings.heading_font_size_mobile }}px;">
          {{ heading_mobile }}
        </h2>
      {%- endif -%}
      {%- if subheading_mobile != blank -%}
        <div class="gift-banner__subheading" style="font-size: {{ section.settings.subheading_font_size_mobile }}px;">
          {{ subheading_mobile | newline_to_br }}
        </div>
      {%- endif -%}
    </div>

    <div class="gift-banner__mobile-media">
      {%- if mobile_image -%}
        <img
          src="{{ mobile_image | image_url: width: 1000 }}"
          srcset="{{ mobile_image | image_url: width: 600 }} 600w, {{ mobile_image | image_url: width: 1000 }} 1000w"
          sizes="100vw"
          width="{{ mobile_image.width }}"
          height="{{ mobile_image.height }}"
          alt="{{ mobile_image.alt | default: heading_mobile | escape }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="gift-banner__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      {%- endif -%}

      {%- if btn_label_mobile != blank -%}
        <div class="gift-banner__button-wrap gift-banner__button-wrap--mobile">
          <a href="{{ btn_link_mobile | default: '#' }}" class="gift-banner__button black" style="font-size: {{ section.settings.button_font_size_mobile }}px;">
            <span>{{ btn_label_mobile }}</span>
            <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
            </svg>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- if note_mobile != blank -%}
      <p class="gift-banner__note">{{ note_mobile }}</p>
    {%- endif -%}

    {%- if bottom_text_mobile != blank -%}
      <div class="gift-banner__bottom-bar">
        <p>{{ bottom_text_mobile }}</p>
      </div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Gift Banner",
  "tag": "section",
  "class": "section-gift-banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop images"
    },
    {
      "type": "image_picker",
      "id": "top_image",
      "label": "Top image (full width)"
    },
    {
      "type": "range",
      "id": "top_image_ratio_w",
      "label": "Top image aspect ratio — width",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 16,
      "info": "Works together with the height value below, e.g. 16 / 4.3 ≈ the 1440×390 proportions shown in your reference image."
    },
    {
      "type": "range",
      "id": "top_image_ratio_h",
      "label": "Top image aspect ratio — height",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 4
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "Bottom-right image"
    },
    {
      "type": "range",
      "id": "text_col_width",
      "label": "Text column width",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "split_row_ratio_w",
      "label": "Text/image row aspect ratio — width",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 16,
      "info": "Controls the height of the bottom row (text column + right image) so it stays proportional at any screen width."
    },
    {
      "type": "range",
      "id": "split_row_ratio_h",
      "label": "Text/image row aspect ratio — height",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Desktop text content"
    },
    {
      "type": "text",
      "id": "heading_desktop",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subheading_desktop",
      "label": "Subheading",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "button_label_desktop",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link_desktop",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "bottom_bar_text_desktop",
      "label": "Bottom bar text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "header",
      "content": "Desktop font sizes"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading font size",
      "min": 30,
      "max": 70,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "subheading_font_size_desktop",
      "label": "Subheading font size",
      "min": 12,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_font_size_desktop",
      "label": "Button font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Banner image (mobile)"
    },
    {
      "type": "range",
      "id": "mobile_image_ratio_w",
      "label": "Mobile image aspect ratio — width",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_image_ratio_h",
      "label": "Mobile image aspect ratio — height",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Mobile text content"
    },
    {
      "type": "text",
      "id": "eyebrow_mobile",
      "label": "Eyebrow text (optional, shown above heading)"
    },
    {
      "type": "text",
      "id": "heading_mobile",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subheading_mobile",
      "label": "Subheading",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "button_label_mobile",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link_mobile",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "note_mobile",
      "label": "Small note text (optional, shown below the image/button)"
    },
    {
      "type": "text",
      "id": "bottom_bar_text_mobile",
      "label": "Bottom bar text",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    },
    {
      "type": "header",
      "content": "Mobile font sizes"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_font_size_mobile",
      "label": "Subheading font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_font_size_mobile",
      "label": "Button font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "bottom_bar_bg_color",
      "label": "Bottom bar background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "bottom_bar_text_color",
      "label": "Bottom bar text",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Gift Banner"
    }
  ]
}
{% endschema %}
