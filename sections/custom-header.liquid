{{ 'component-custom-header.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign logo_image = section.settings.logo_image
  assign site_name = section.settings.site_name | default: shop.name
  assign tagline = section.settings.tagline
  assign btn_label = section.settings.button_label
  assign btn_link = section.settings.button_link
-%}

<header class="cheader color-{{ section.settings.color_scheme }}"
        data-cheader
        id="CustomHeader-{{ section.id }}"
        style="
          --cheader-bg: {{ section.settings.background_color }};
          --cheader-text: {{ section.settings.text_color }};
          --cheader-btn-bg: {{ section.settings.button_bg_color }};
          --cheader-btn-text: {{ section.settings.button_text_color }};
          --cheader-logo-width: {{ section.settings.logo_width }}px;
        ">
  <div class="cheader__row page-width">

    <div class="cheader__left">
      <button type="button"
              class="cheader__toggle"
              data-cheader-toggle
              aria-expanded="false"
              aria-controls="CustomHeaderPanel-{{ section.id }}"
              aria-label="Toggle menu">
        <span class="cheader__icon cheader__icon--menu">
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 6H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 1H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 11H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="cheader__icon cheader__icon--close">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 13.9994L13.7279 1.2715" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 1L13.7279 13.7279" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <a href="{{ routes.root_url }}" class="cheader__logo-link">
        {%- if logo_image -%}
          <img
            src="{{ logo_image | image_url: width: 600 }}"
            alt="{{ site_name | escape }}"
            width="{{ logo_image.width }}"
            height="{{ logo_image.height }}"
            class="cheader__logo-image"
            loading="eager"
          >
        {%- else -%}
          <span class="cheader__site-name">{{ site_name }}</span>
        {%- endif -%}
      </a>
    </div>

    <div class="cheader__center">
      {%- if tagline != blank -%}
        <p class="cheader__tagline">{{ tagline }}</p>
      {%- endif -%}
    </div>

    <div class="cheader__right">
      {%- if btn_label != blank -%}
        <a href="{{ btn_link | default: '#' }}" class="cheader__button">
          <span>{{ btn_label }}</span>
          <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="black"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

  </div>

  <div class="cheader__panel" id="CustomHeaderPanel-{{ section.id }}" data-cheader-panel>
    <div class="cheader__panel-inner">
      {%- if tagline != blank -%}
        <p class="cheader__tagline cheader__tagline--mobile">{{ tagline }}</p>
      {%- endif -%}
      {%- if btn_label != blank -%}
        <a href="{{ btn_link | default: '#' }}" class="cheader__button cheader__button--mobile">
          <span>{{ btn_label }}</span>
          <svg width="29" height="12" viewBox="0 0 29 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0.75 4.77298L6.72657e-08 4.77298L-6.72657e-08 6.27298L0.75 6.27298L0.75 4.77298ZM28.6378 6.05331C28.9307 5.76042 28.9307 5.28555 28.6378 4.99265L23.8649 0.219681C23.572 -0.0732126 23.0971 -0.0732126 22.8042 0.219681C22.5113 0.512574 22.5113 0.987448 22.8042 1.28034L27.0469 5.52298L22.8042 9.76562C22.5113 10.0585 22.5113 10.5334 22.8042 10.8263C23.0971 11.1192 23.572 11.1192 23.8649 10.8263L28.6378 6.05331ZM0.75 6.27298L28.1075 6.27298L28.1075 4.77298L0.75 4.77298L0.75 6.27298Z" fill="black"/>
          </svg>       
        </a>
      {%- endif -%}
    </div>
  </div>
</header>

<script src="{{ 'component-custom-header.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Custom Header",
  "tag": "section",
  "class": "section-custom-header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image",
      "info": "If no logo is uploaded, the site name text below will display instead."
    },
    {
      "type": "text",
      "id": "site_name",
      "label": "Site name (fallback text)",
      "info": "Shown only when no logo image is uploaded. Leave blank to use your store name.",
      "default": "TISSO VISON"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo image width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Tagline & Button"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Choose gift"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#F4E727"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}
